#!/usr/bin/env bash
#
# amb — build the Investment Committee memo and serve it live.
#
#   ./launch        build + serve + open the live app   (real FRED API call in-browser)
#   ./amb           same as ./launch
#   ./amb open      quick static build + open           (no server, snapshot benchmark)
#   ./amb serve     serve without auto-opening a browser (headless)
#   ./amb test      run the test suite
#   ./amb setup     (re)install dependencies only
#   ./amb -h        help
#
set -uo pipefail
cd "$(dirname "$0")"

VENV=".venv"; PY="$VENV/bin/python"; PIP="$VENV/bin/pip"

if [ -t 1 ]; then
  B='\033[1m'; D='\033[2m'; G='\033[0;32m'; C='\033[0;36m'; Y='\033[1;33m'; R='\033[0;31m'; N='\033[0m'
else B=''; D=''; G=''; C=''; Y=''; R=''; N=''; fi
ok(){ echo -e "${G}✓${N} $*"; }; info(){ echo -e "${C}ℹ${N} $*"; }
warn(){ echo -e "${Y}!${N} $*"; }; err(){ echo -e "${R}✗${N} $*"; }; step(){ echo -e "${B}▸ $*${N}"; }

[ -f .env ] && { set -a; . ./.env 2>/dev/null || true; set +a; }

ready(){ [ -x "$PY" ] && "$PY" -c "import amb_core, pandas, pydantic" >/dev/null 2>&1; }

setup(){
  step "Setting up (first run only)…"
  command -v python3 >/dev/null 2>&1 || { err "Python 3 not found — please install it first."; return 1; }
  [ -x "$PY" ] || python3 -m venv "$VENV" || { err "could not create virtualenv"; return 1; }
  "$PY" -m pip install --upgrade pip -q >/dev/null 2>&1 || true
  "$PIP" install -q -r requirements.txt >/dev/null 2>&1 || { err "dependency install failed"; return 1; }
  "$PIP" install -q -e ./backend >/dev/null 2>&1 || true
  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env; }
  mkdir -p data/local exports
  ok "Ready."
}

open_it(){  # open a file OR url in the default browser, cross-platform
  local f="$1"
  if   command -v open     >/dev/null 2>&1; then open "$f"
  elif command -v xdg-open >/dev/null 2>&1; then (xdg-open "$f" >/dev/null 2>&1 &)
  elif command -v wslview  >/dev/null 2>&1; then wslview "$f"
  else info "Open this in your browser: ${B}$f${N}"; fi
}

build_memo(){
  ready || setup || return 1
  step "Building the memo…"
  "$PY" -m amb_core.demo "$@" || { err "build failed"; return 1; }
}

build_open(){  # quick static look — no server
  build_memo "$@" || return 1
  if [ -f exports/memo.html ]; then ok "Opening exports/memo.html"; open_it exports/memo.html
  else warn "no memo.html was produced"; fi
}

serve_live(){  # $1 = "open" to auto-open the browser once the server is up
  local autoopen="$1"; shift || true
  build_memo "$@" || return 1
  local HOST="${AMB_SERVE_HOST:-127.0.0.1}" PORT="${AMB_SERVE_PORT:-8000}"
  local URL="http://$HOST:$PORT"
  if [ "$autoopen" = "open" ]; then
    ok "Live app → ${B}${URL}${N}   ${D}(real FRED API call in your browser · Ctrl+C to stop)${N}"
    ( if command -v curl >/dev/null 2>&1; then
        for _ in $(seq 1 80); do curl -fsS -o /dev/null "$URL/api/health" 2>/dev/null && break; sleep 0.3; done
      else sleep 2; fi
      open_it "$URL" ) &
  else
    info "Serving at ${B}${URL}${N} — open it for live market data (Ctrl+C to stop)"
  fi
  "$PY" -c "from amb_core.serve import run_server; raise SystemExit(run_server())"
}

case "${1:-}" in
  ""|launch|live|start) serve_live open "${@:2}" ;;
  open|build)           build_open "${@:2}" ;;
  serve)                serve_live noopen "${@:2}" ;;
  setup)                setup ;;
  test)                 ready || setup; "$PY" -m pytest -q "${@:2}" ;;
  -h|--help|help)
    echo ""
    echo -e "  ${B}amb${N} — build the IC memo and serve it live (real FRED API call in-browser)"
    echo ""
    echo -e "    ${C}./launch${N}      build + serve + open the live app  ${D}(one command — recommended)${N}"
    echo -e "    ${C}./amb${N}         same as ./launch"
    echo -e "    ${C}./amb open${N}    quick static build + open  ${D}(no server, snapshot benchmark)${N}"
    echo -e "    ${C}./amb serve${N}   serve without auto-opening a browser"
    echo -e "    ${C}./amb test${N}    run the test suite"
    echo -e "    ${C}./amb setup${N}   (re)install dependencies only"
    echo "" ;;
  *) err "unknown option: $1"; echo -e "  try ${C}./launch${N} or ${C}./amb -h${N}" ;;
esac
