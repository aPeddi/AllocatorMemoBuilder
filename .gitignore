__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
build/
dist/

# Node / frontend
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# Env & secrets  (keep the example, ignore real ones)
.env
.env.*
!.env.example

# Local data / databases / generated artifacts
*.sqlite
*.sqlite3
*.db
data/local/
.cache/
artifacts/
exports/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Editor / patch backups (safe to delete)
*.bak
*.bak*
_to_delete/

# Runtime market-data cache (regenerated on demand)
data/benchmarks/cache/
data/local/
