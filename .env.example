# ─────────────────────────────────────────────────────────────
# AllocatorMemoBuilder — local config template
# Copy to .env (git-ignored) and fill in:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

AMB_ENV=local
AMB_LOG_LEVEL=info

# ── LLM (Anthropic, direct) ──────────────────────────────────
# One key. Smart routing: a fast model for extraction/validation,
# a strong model for drafting + risk review.
ANTHROPIC_API_KEY=
AMB_MODEL_FAST=claude-haiku-4-5-20251001
AMB_MODEL_STRONG=claude-sonnet-4-6

# ── Storage (local-first) ────────────────────────────────────
AMB_DATABASE_URL=sqlite:///./data/local/amb.sqlite

# ── Benchmarks & risk-free ───────────────────────────────────
# snapshot = cached as-of fixtures (reproducible, default); live = fetch at runtime.
AMB_BENCHMARK_MODE=snapshot
AMB_RISK_FREE_ANNUAL=0.02
FRED_API_KEY=

# ── Live market data (FRED) ─────────────────────────────────
# Free key from https://fredaccount.stlouisfed.org/apikey — used server-side
# only by `./amb serve`; never shipped to the browser.
AMB_SERVE_HOST=127.0.0.1
AMB_SERVE_PORT=8000
