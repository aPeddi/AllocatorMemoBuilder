# ─────────────────────────────────────────────────────────────
# AllocatorMemoBuilder — local config template
# Copy to .env (git-ignored) and fill in:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

AMB_ENV=local
AMB_LOG_LEVEL=info

# ── LLM routing (OpenRouter — provider-agnostic) ─────────────
# One key, many models. Smart routing uses a cheap model for
# extraction/validation and a strong model for drafting/risk review.
OPENROUTER_API_KEY=
AMB_MODEL_FAST=            # small/cheap model slug for extraction + validation
AMB_MODEL_STRONG=         # strong model slug for drafting + risk review

# ── Storage (local-first) ────────────────────────────────────
# SQLite by default; override with a Postgres URL if you want.
AMB_DATABASE_URL=sqlite:///./data/local/amb.sqlite

# ── External benchmark data ──────────────────────────────────
# 'snapshot' = use cached as-of fixtures (reproducible, auditable, default).
# 'live'     = pull from FRED / market data at runtime (non-deterministic).
AMB_BENCHMARK_MODE=snapshot
FRED_API_KEY=
